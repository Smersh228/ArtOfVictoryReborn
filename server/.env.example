# Скопируйте в .env на VPS: cp .env.example .env && nano .env
# Значения ниже — примеры, подставьте свои.

NODE_ENV=production

# Порт API (Nginx проксирует сюда, например location /api → 127.0.0.1:5000)
PORT=5000

# Origin фронтенда (куки CORS + SameSite): точный URL сайта со схемой, без слэша в конце
CLIENT_ORIGIN=https://ваш-домен.ru

# PostgreSQL (как в вашей установке на VPS)
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=имя_базы
DB_USER=пользователь_бд
DB_PASSWORD=надёжный_пароль

# Секрет подписи JWT (длинная случайная строка, не светите в git)
JWT_SECRET=замените_на_случайную_строку_32_символа_и_больше

# Имя httpOnly-куки с токеном (можно не менять)
JWT_COOKIE_NAME=aov_access_token

# Куки только по HTTPS: на VPS с SSL оставьте true; для локального http без SSL — false
COOKIE_SECURE=true
